# ─── Segurança (OBRIGATÓRIO mudar em produção) ──────────────────────────────
# openssl rand -hex 32
SECRET_KEY=dev-secret-change-in-production-use-openssl-rand-hex-32

# Chave usada pelos plugins analytics para autenticar na API do VMS
# Header: Authorization: ApiKey <key>
VMS_API_KEY=dev-analytics-key-change-in-production

# ─── Domínio ─────────────────────────────────────────────────────────────────
# Em produção: seu domínio real (ex: vms.meuintegrador.com.br)
DOMAIN=localhost

# ─── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_USER=vms
POSTGRES_DB=vms
POSTGRES_PASSWORD=vmsdev
DATABASE_URL=postgresql+asyncpg://vms:vmsdev@postgres:5432/vms

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=vms
RABBITMQ_PASSWORD=vmsdev
RABBITMQ_URL=amqp://vms:vmsdev@rabbitmq:5672/

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MediaMTX ────────────────────────────────────────────────────────────────
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_RTMP_URL=rtmp://mediamtx:1935
MEDIAMTX_HLS_URL=http://mediamtx:8888

# URL pública RTMP — usada no wizard para o integrador configurar a câmera
# Em produção: rtmp://vms.seudominio.com.br:1935
RTMP_PUBLIC_URL=rtmp://localhost:1935

# ─── TURN Server (opcional — necessário para WebRTC em NAT simétrico) ────────
# Deixar em branco para usar apenas STUN público (stun.l.google.com)
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ─── Gravações ───────────────────────────────────────────────────────────────
RECORDINGS_PATH=/recordings

# ─── Analytics (serviço standalone) ──────────────────────────────────────────
ANALYTICS_FPS=1
ANALYTICS_WORKERS=4
YOLO_IMGSZ=640
YOLO_CONF=0.30

# ─── ALPR ────────────────────────────────────────────────────────────────────
ALPR_DEDUP_TTL_SECONDS=60

# ─── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_CAMERAS=200

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_WEBHOOKS=100/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=60/minute

# ─── Backup ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7
