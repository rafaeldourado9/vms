# ─── Identidade (white-label) ─────────────────────────────────────────────────
# Nome exibido na sidebar e no título da página
VITE_APP_NAME=VMS

# Cor de destaque em hex (botões, links, itens ativos do nav)
VITE_ACCENT_COLOR=#3B82F6

# ─── API ──────────────────────────────────────────────────────────────────────
# Em produção: deixar vazio — o frontend usa URL relativa (/api/v1) via nginx
# Em desenvolvimento apontando para API remota: http://meu-servidor:8000
VITE_API_URL=
